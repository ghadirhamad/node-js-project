<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>مقالة جديدة</title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <%- include("partials/header") %>

  <div class="container">
    <a href="/" class="btn btn-secondary" style="margin-bottom:24px; display:inline-flex;">← العودة</a>

    <h1 class="page-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#6C63FF" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
      </svg>
      إضافة مقالة جديدة
    </h1>

    <div class="card" style="padding:40px;">
      <form action="/article" method="POST">
        <div style="margin-bottom:24px;">
          <label for="articleTitle" style="display:block; font-weight:600; margin-bottom:8px; color:var(--text);">عنوان المقال</label>
          <input type="text" name="articleTitle" id="articleTitle" required
            placeholder="اكتب عنواناً جذاباً..."
            style="width:100%; padding:14px 16px; border:2px solid var(--border); border-radius:12px; font-size:16px; font-family:'Tajawal',sans-serif; outline:none; transition:border 0.2s ease; background:var(--bg);"
            onfocus="this.style.borderColor='#6C63FF'" onblur="this.style.borderColor='var(--border)'">
        </div>

        <div style="margin-bottom:32px;">
          <label for="articleBody" style="display:block; font-weight:600; margin-bottom:8px; color:var(--text);">محتوى المقال</label>
          <textarea name="articleBody" id="articleBody" required
            placeholder="اكتب مقالتك هنا..."
            style="width:100%; padding:14px 16px; border:2px solid var(--border); border-radius:12px; font-size:16px; font-family:'Tajawal',sans-serif; outline:none; transition:border 0.2s ease; background:var(--bg); height:260px; resize:vertical; line-height:1.8;"
            onfocus="this.style.borderColor='#6C63FF'" onblur="this.style.borderColor='var(--border)'"></textarea>
        </div>

        <button type="submit" class="btn btn-success" style="font-size:16px; padding:14px 32px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
          نشر المقال
        </button>
      </form>
    </div>
  </div>
</body>
</html>
