<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>كل المقالات</title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <%- include("partials/header") %>

  <div class="container">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:32px; flex-wrap:wrap; gap:12px;">
      <h1 class="page-title" style="margin-bottom:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#6C63FF" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
        </svg>
        قائمة المقالات
      </h1>
      <div style="display:flex; gap:10px;">
        <a href="/" class="btn btn-secondary">العودة</a>
        <% if (!user) { %>
          <a href="/auth/google" class="btn btn-primary">تسجيل الدخول</a>
        <% } else { %>
          <a href="/logout" class="btn btn-secondary">تسجيل الخروج</a>
        <% } %>
      </div>
    </div>

    <% if (allArticles.length === 0) { %>
      <div class="card" style="text-align:center; padding:60px 24px; color:var(--text-light);">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="none" viewBox="0 0 24 24" stroke="#CBD5E0" stroke-width="1.5" style="margin-bottom:16px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <p style="font-size:18px; margin-bottom:16px;">لا توجد مقالات بعد</p>
        <a href="/article/new" class="btn btn-primary">أضف أول مقالة ✍️</a>
      </div>
    <% } else { %>
      <div style="display:flex; flex-direction:column; gap:16px;">
        <% allArticles.forEach(article => { %>
          <a href="/article/<%= article._id %>" style="text-decoration:none;">
            <div class="card" style="display:flex; justify-content:space-between; align-items:center;">
              <div>
                <div style="font-size:18px; font-weight:700; color:var(--text); margin-bottom:6px;"><%= article.title %></div>
                <div style="font-size:14px; color:var(--text-light);">بقلم <%= article.author %></div>
              </div>
              <div style="display:flex; align-items:center; gap:6px; color:var(--secondary); font-weight:600; white-space:nowrap;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="<%= article.likes > 0 ? '#FF6584' : 'none' %>" stroke="#FF6584" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                </svg>
                <%= article.likes %>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>
