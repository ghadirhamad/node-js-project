<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= article.title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <%- include("partials/header") %>

  <div class="container">
    <a href="/show" class="btn btn-secondary" style="margin-bottom:24px; display:inline-flex;">
      ← العودة للمقالات
    </a>

    <div class="card" style="padding:40px;">
      <h1 style="font-size:30px; font-weight:700; color:var(--text); margin-bottom:16px; line-height:1.4;">
        <%= article.title %>
      </h1>

      <div style="display:flex; align-items:center; gap:8px; color:var(--text-light); font-size:14px; margin-bottom:32px; padding-bottom:24px; border-bottom:1px solid var(--border);">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        <span>بقلم <strong style="color:var(--text);"><%= article.author %></strong></span>
      </div>

      <p style="font-size:18px; line-height:2; color:var(--text); margin-bottom:40px;">
        <%= article.body %>
      </p>

      <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px; padding-top:24px; border-top:1px solid var(--border);">

        <form action="/article/<%= article._id %>/like" method="POST">
          <button type="submit" style="background:none; border:2px solid var(--border); border-radius:50px; padding:10px 20px; cursor:pointer; display:flex; align-items:center; gap:8px; font-size:16px; font-family:'Tajawal',sans-serif; color:var(--text); transition:all 0.2s ease;">
            <% if (user && article.likedBy.includes(user.emails[0].value)) { %>
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#FF6584" viewBox="0 0 24 24">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
              <span style="color:#FF6584; font-weight:700;"><%= article.likes %> إعجاب</span>
            <% } else { %>
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="#FF6584" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
              <span><%= article.likes %> إعجاب</span>
            <% } %>
          </button>
        </form>

        <% if (user && user.emails[0].value === article.author) { %>
          <form action="/article/<%= article._id %>?_method=DELETE" method="POST" onsubmit="return confirm('هل أنت متأكد من حذف هذه المقالة؟');">
            <button type="submit" class="btn btn-danger">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
              حذف المقال
            </button>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
