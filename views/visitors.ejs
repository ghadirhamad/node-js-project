<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>مقالاتي</title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <%- include("partials/header") %>

  <div style="min-height:calc(100vh - 70px); display:flex; align-items:center; justify-content:center; padding:24px;">
    <div style="text-align:center; max-width:600px;">

      <div style="width:100px; height:100px; background:linear-gradient(135deg, #6C63FF 0%, #FF6584 100%); border-radius:30px; display:flex; align-items:center; justify-content:center; margin:0 auto 32px; box-shadow:0 12px 40px rgba(108,99,255,0.3);">
        <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
      </div>

      <% if (user) { %>
        <h1 style="font-size:32px; font-weight:700; margin-bottom:8px;">أهلاً، <span style="color:var(--primary);"><%= user.displayName %></span> 👋</h1>
      <% } else if (userType === "guest") { %>
        <h1 style="font-size:32px; font-weight:700; margin-bottom:8px;">أهلاً أيها الزائر 👤</h1>
      <% } %>

      <p style="color:var(--text-light); font-size:17px; margin-bottom:40px; line-height:1.8;">
        منصتك لكتابة ومشاركة المقالات الملهمة. ابدأ بكتابة أفكارك أو استكشف ما كتبه الآخرون.
      </p>

      <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
        <a href="/article/new" class="btn btn-primary" style="padding:14px 28px; font-size:16px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
          كتابة مقالة
        </a>

        <a href="/show" class="btn btn-secondary" style="padding:14px 28px; font-size:16px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
          </svg>
          استعراض المقالات
        </a>

        <% if (user) { %>
          <a href="/logout" class="btn btn-gray" style="padding:14px 28px; font-size:16px;">تسجيل الخروج</a>
        <% } else if (userType === "guest") { %>
          <a href="/logout" class="btn btn-primary" style="padding:14px 28px; font-size:16px;">تسجيل الدخول</a>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
